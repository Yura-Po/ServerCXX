    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Debug Server (build before run)",
            "type": "cppdbg",
            "request": "launch",
            "program": "/home/user/ServerCXX/build/Server",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "cmake build",
        },

        {
            "name": "Debug Server (NO build)",
            "type": "cppdbg",
            "request": "launch",
            "program": "/home/user/ServerCXX/build/Server",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}